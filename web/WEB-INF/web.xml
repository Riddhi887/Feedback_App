<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">
    <display-name>Web Application</display-name>
    <!-- Each servlet has its config obj to store key information-->
    <context-param>
        <param-name>app_name</param-name>
        <param-value>FeedbackApp</param-value>
    </context-param>

    <!-- Creating config obj for Req1 and 2 servlet-->
    <servlet>
        <servlet-name>servlet1</servlet-name>
        <servlet-class>session.manage.Request1Servlet</servlet-class>
        <init-param>
            <param-name>userName</param-name>
            <param-value>riddhi</param-value>
        </init-param>
    </servlet>
    <servlet-mapping>
        <servlet-name>servlet1</servlet-name>
        <url-pattern>/servlet1</url-pattern>
    </servlet-mapping>

    <servlet>
        <servlet-name>servlet2</servlet-name>
        <servlet-class>session.manage.Request2Servlet</servlet-class>
        <init-param>
            <param-name>userEmail</param-name>
            <param-value>abc@gmail.com</param-value>
        </init-param>
    </servlet>
    <servlet-mapping>
        <servlet-name>servlet2</servlet-name>
        <url-pattern>/servlet2</url-pattern>
    </servlet-mapping>
</web-app>